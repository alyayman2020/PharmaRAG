# Required for embedding, synthesis, and the LLM input guard.
OPENAI_API_KEY=sk-...

# Set after your first snapshot build. Appears in every audit record.
CORPUS_VERSION=dev
GRAPH_VERSION=none

# Stays "uncalibrated" until milestone C5 fits the Platt calibrator (ADR-026).
# Do NOT describe abstention as "calibrated" while this reads uncalibrated.
CALIBRATOR_VERSION=uncalibrated

# auto | cuda | cpu
DEVICE=auto

# Qdrant server URL. REQUIRED at the 1000-drug corpus size — embedded local mode
# (unset) loads the entire collection into Python memory at startup (6+ GB RAM,
# minutes of silent hang). Start the server with: scripts\start_qdrant.ps1
QDRANT_URL=http://localhost:6333

# Only needed behind a TLS-inspecting proxy (Avast, Zscaler, Kaspersky), which
# re-signs certificates and so breaks default verification. Relative paths
# resolve against the repo root. Leave unset otherwise.
# PHARMARAG_CA_BUNDLE=certs/ca-bundle-avast.pem
